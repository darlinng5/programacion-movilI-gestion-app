<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GestionLibros.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:GestionLibros.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="GestionLibros">

    <TabBar>
        <ShellContent
            Title="Libros"
            ContentTemplate="{DataTemplate local:BookPage}"
            Route="books" />
        <ShellContent
            Title="Categorías"
            ContentTemplate="{DataTemplate local:CategoryPage}"
            Route="categories" />
        <ShellContent
            Title="Estadísticas"
            ContentTemplate="{DataTemplate local:StatsPage}"
            Route="stats" />
    </TabBar>

</Shell>
