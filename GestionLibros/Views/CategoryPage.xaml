<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GestionLibros.Views.CategoryPage"
             Title="Categorías">

    <Grid Padding="20" RowDefinitions="Auto,*" RowSpacing="16">
        <VerticalStackLayout Grid.Row="0" Spacing="12">
            <Label Text="Nombre"/>
            <Entry Text="{Binding Name}"
                   Placeholder="Ingrese el nombre de la categoría" />
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Button
                    Grid.Column="0"
                    Text="Save"
                    Command="{Binding SaveCommand}"
                    />
                <Button Grid.Column="1"
                        Text="Update"
                        Command="{Binding UpdateCommand}"
                        />
                <Button Grid.Column="2"
                        Text="Delete"
                        Command="{Binding DeleteCommand}"
                        />
            </Grid>
        </VerticalStackLayout>
        <CollectionView SelectedItem="{Binding SelectedCategory}" SelectionMode="Single"
                        Grid.Row="1" ItemsSource="{Binding Categories}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="0,8">
                        <Label Text="{Binding Name}"/>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
