<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GestionLibros.Views.CategoryPage"
             Title="Categorías">

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Grid.Row="0" Padding="20,16,20,8" Spacing="14">
            <Label Text="Categorías" Style="{StaticResource PageTitle}"/>
            <Label Text="{Binding Categories.Count, StringFormat='{0} categoría(s) creadas'}"
                   Style="{StaticResource PageSubtitle}"/>

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Nueva categoría / Editar" Style="{StaticResource SectionTitle}" Margin="0"/>
                    <Label Text="Nombre" Style="{StaticResource FieldLabel}"/>
                    <Entry Text="{Binding Name}"
                           Placeholder="Ej. Ciencia ficción" />
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8" Margin="0,8,0,0">
                        <Button Grid.Column="0" Text="Guardar" Command="{Binding SaveCommand}" />
                        <Button Grid.Column="1" Text="Actualizar" Style="{StaticResource OutlineButton}"
                                Command="{Binding UpdateCommand}" />
                        <Button Grid.Column="2" Text="Eliminar" Style="{StaticResource DangerButton}"
                                Command="{Binding DeleteCommand}" />
                        <Button Grid.Column="3" Text="Cancelar" Style="{StaticResource OutlineButton}"
                                Command="{Binding ClearFormCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Label Text="Todas las categorías" Style="{StaticResource SectionTitle}"/>
        </VerticalStackLayout>

        <CollectionView SelectedItem="{Binding SelectedCategory}" SelectionMode="Single"
                        Grid.Row="1" ItemsSource="{Binding Categories}"
                        Margin="20,0,20,20">
            <CollectionView.EmptyView>
                <VerticalStackLayout>
                    <Label Text="🏷️" FontSize="40" HorizontalTextAlignment="Center"/>
                    <Label Text="Aún no tienes categorías. ¡Crea la primera!"
                           Style="{StaticResource EmptyStateLabel}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="16,12">
                        <Label Text="{Binding Name}" Style="{StaticResource BookTitleLabel}"/>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
