<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GestionLibros.Views.CategoryPage"
             Title="Categorías">

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Grid.Row="0" Padding="20,16,20,8" Spacing="14">
            <Label Text="Categorías" Style="{StaticResource PageTitle}"/>
            <Label Text="{Binding Categories.Count, StringFormat='{0} categoría(s) creadas'}"
                   Style="{StaticResource PageSubtitle}"/>

            <Button Text="＋ Nueva categoría" Clicked="OnNewCategoryClicked" />
        </VerticalStackLayout>

        <CollectionView SelectionMode="None"
                        Grid.Row="1" ItemsSource="{Binding Categories}"
                        Margin="20,0,20,20">
            <CollectionView.EmptyView>
                <VerticalStackLayout>
                    <Label Text="🏷️" FontSize="40" HorizontalTextAlignment="Center"/>
                    <Label Text="Aún no tienes categorías. ¡Crea la primera!"
                           Style="{StaticResource EmptyStateLabel}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding Name}" Style="{StaticResource BookTitleLabel}"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Grid.Column="0" Text="✏️ Editar" Style="{StaticResource OutlineButton}"
                                        CommandParameter="{Binding .}" Clicked="OnEditClicked" />
                                <Button Grid.Column="1" Text="🗑️ Eliminar" Style="{StaticResource DangerButton}"
                                        CommandParameter="{Binding .}" Clicked="OnDeleteClicked" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
