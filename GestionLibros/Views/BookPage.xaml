<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:GestionLibros.Converters"
             x:Class="GestionLibros.Views.BookPage"
             Title="Libros">

    <ContentPage.Resources>
        <converters:CategoryIdToNameConverter x:Key="CategoryIdToNameConverter" />
        <converters:RatingToStarsConverter x:Key="RatingToStarsConverter" />
        <converters:ReadingStatusToLabelConverter x:Key="ReadingStatusToLabelConverter" />
        <converters:ReadingStatusToColorConverter x:Key="ReadingStatusToColorConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,16,20,8" Spacing="14">
                <Label Text="Mi Biblioteca" Style="{StaticResource PageTitle}"/>
                <Label Text="{Binding Books.Count, StringFormat='{0} libro(s) en tu colección'}"
                       Style="{StaticResource PageSubtitle}"/>

                <SearchBar Placeholder="Buscar por nombre o autor"
                           Text="{Binding SearchText}" />

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Nuevo libro / Editar" Style="{StaticResource SectionTitle}" Margin="0"/>

                        <Label Text="Nombre" Style="{StaticResource FieldLabel}"/>
                        <Entry Text="{Binding Name}" Placeholder="Ej. Cien años de soledad" />

                        <Label Text="Autor" Style="{StaticResource FieldLabel}"/>
                        <Entry Text="{Binding Author}" Placeholder="Ej. Gabriel García Márquez" />

                        <Label Text="Descripción" Style="{StaticResource FieldLabel}"/>
                        <Editor Text="{Binding Description}"
                                Placeholder="Breve sinopsis del libro..."
                                AutoSize="TextChanges"
                                HeightRequest="80" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="Categoría" Style="{StaticResource FieldLabel}"/>
                                <Picker ItemsSource="{Binding Categories}"
                                        ItemDisplayBinding="{Binding Name}"
                                        SelectedItem="{Binding SelectedCategory}"
                                        Title="Selecciona" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="6">
                                <Label Text="Estado" Style="{StaticResource FieldLabel}"/>
                                <Picker ItemsSource="{Binding Statuses}"
                                        SelectedItem="{Binding SelectedStatus}">
                                    <Picker.ItemDisplayBinding>
                                        <Binding Path="." Converter="{StaticResource ReadingStatusToLabelConverter}" />
                                    </Picker.ItemDisplayBinding>
                                </Picker>
                            </VerticalStackLayout>
                        </Grid>

                        <Label Text="Calificación" Style="{StaticResource FieldLabel}"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <Stepper Grid.Column="0" Minimum="0" Maximum="5" Increment="1"
                                     Value="{Binding Rating}" HorizontalOptions="Start" />
                            <Label Grid.Column="1"
                                   Text="{Binding Rating, Converter={StaticResource RatingToStarsConverter}}"
                                   TextColor="{StaticResource Warning}"
                                   FontSize="18" VerticalOptions="Center" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8" Margin="0,8,0,0">
                            <Button Grid.Column="0" Text="Guardar" Command="{Binding SaveCommand}" />
                            <Button Grid.Column="1" Text="Actualizar" Style="{StaticResource OutlineButton}"
                                    Command="{Binding UpdateCommand}" />
                            <Button Grid.Column="2" Text="Eliminar" Style="{StaticResource DangerButton}"
                                    Command="{Binding DeleteCommand}" />
                            <Button Grid.Column="3" Text="Cancelar" Style="{StaticResource OutlineButton}"
                                    Command="{Binding ClearFormCommand}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Label Text="Libros" Style="{StaticResource SectionTitle}"/>
            </VerticalStackLayout>
        </ScrollView>

        <CollectionView SelectedItem="{Binding SelectedBook}" SelectionMode="Single"
                        Grid.Row="1" ItemsSource="{Binding Books}"
                        Margin="20,0,20,20">
            <CollectionView.EmptyView>
                <VerticalStackLayout>
                    <Label Text="📭" FontSize="40" HorizontalTextAlignment="Center"/>
                    <Label Text="No hay libros que coincidan. ¡Agrega el primero!"
                           Style="{StaticResource EmptyStateLabel}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                        <VerticalStackLayout Spacing="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="{Binding Name}" Style="{StaticResource BookTitleLabel}"/>
                                <Label Grid.Column="1"
                                       Text="{Binding Rating, Converter={StaticResource RatingToStarsConverter}}"
                                       TextColor="{StaticResource Warning}" FontSize="14" VerticalOptions="Center"/>
                            </Grid>
                            <Label Text="{Binding Author, StringFormat='✍️ {0}'}" Style="{StaticResource MutedLabel}"/>
                            <Label Text="{Binding Description}" Style="{StaticResource MutedLabel}"
                                   MaxLines="2" LineBreakMode="TailTruncation"/>
                            <HorizontalStackLayout Spacing="8" Margin="0,4,0,0">
                                <Border Style="{StaticResource BadgeBorder}">
                                    <Label Style="{StaticResource BadgeLabel}"
                                           Text="{Binding CategoryId, Converter={StaticResource CategoryIdToNameConverter}}"/>
                                </Border>
                                <Border StrokeShape="RoundRectangle 20" StrokeThickness="0" Padding="10,4"
                                        BackgroundColor="{Binding Status, Converter={StaticResource ReadingStatusToColorConverter}}">
                                    <Label FontSize="12" FontAttributes="Bold" TextColor="White"
                                           Text="{Binding Status, Converter={StaticResource ReadingStatusToLabelConverter}}"/>
                                </Border>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
