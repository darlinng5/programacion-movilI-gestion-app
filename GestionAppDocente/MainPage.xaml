<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:GestionAppDocente.ViewModels"
             x:Class="GestionAppDocente.MainPage">
    <ContentPage.BindingContext>
        <viewmodel:MainViewModel></viewmodel:MainViewModel>
    </ContentPage.BindingContext>
    
    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                Source="dotnet_bot.png"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="dot net bot in a race car number eight" />

            <Label
                Text="Programación para Móviles I"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Boton de sumar y restar"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Welcome to dot net Multi platform App U I" />

            <Button
                x:Name="CounterBtn"
                Text="{Binding Count}" 
                SemanticProperties.Hint="Counts the number of times you click"
                Command="{Binding SumarCommand}"
                HorizontalOptions="Fill" />
            <Button
                x:Name="RestBtn"
                Text="{Binding Rest}" 
                SemanticProperties.Hint="Counts the number of times you click"
                Command="{Binding RestarCommand}"
                HorizontalOptions="Fill" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
